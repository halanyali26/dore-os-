# Dore OS v2.0 — Environment Configuration
# Copy to .env and fill in your credentials.

# ─── LLM Providers ──────────────────────────
# Hermes (local Llama server)
HERMES_BASE_URL=http://localhost:8080/v1
HERMES_MODEL=local-model

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Anthropic Claude (optional fallback)
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Spotify ────────────────────────────────
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ─── YouTube ────────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-key

# ─── DistroKid ──────────────────────────────
DISTROKID_EMAIL=your-distrokid-email
DISTROKID_PASSWORD=your-distrokid-password

# ─── Composio MCP ───────────────────────────
COMPOSIO_API_KEY=your-composio-api-key

# ─── Observability (LangFuse) ───────────────
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key
LANGFUSE_HOST=http://localhost:3000

# ─── Dore OS ────────────────────────────────
DORE_OS_HOME=/Users/dorestudio/Dore OS
DORE_DASHBOARD_PORT=8700
